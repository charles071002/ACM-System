# Copy this file to `.env` for local development (never commit `.env`).
#
# --- Step 4: database (this repo uses DB_* only; not Railway’s MYSQL* names) ---
# Map Railway Variables → these keys:
#   MYSQLUSER   → DB_USER
#   MYSQLPASSWORD → DB_PASSWORD
#   MYSQLDATABASE → DB_NAME
# For host/port from Render (or your PC) to Railway MySQL, use the public
# TCP Proxy from Railway: MySQL service → Settings → Networking → TCP Proxy.
# Do NOT use mysql.railway.internal as DB_HOST outside Railway’s network.

PORT=5000
CLIENT_ORIGIN=http://localhost:3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=acm_db

DB_PROFESSORS_TABLE=professors
DB_PIN_COLUMN=pincode
DB_NAME_COLUMN=professor
DB_COMPARTMENT_COLUMN=compartment_qr
DB_DEV_TABLE=developer
DB_DEV_USERNAME_COLUMN=developer
DB_DEV_PASSWORD_COLUMN=password
DEV_USERNAME=developer
DEV_PASSWORD=111111
